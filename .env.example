POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webhooks
DATABASE_URL=postgresql://postgres:postgres@db:5432/webhooks

# SQS — LocalStack for local dev, real AWS SQS in production (injected via EC2 user_data)
SQS_QUEUE_URL=http://localstack:4566/000000000000/events-queue
AWS_ENDPOINT_URL=http://localstack:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test